<!-- ARTICLE READER -->
<div class="reader-backdrop" id="backdrop"></div>
<article class="reader" id="reader" aria-hidden="true">
  <div class="reader-inner">
    <button class="reader-close" id="readerClose" aria-label="Close article">✕</button>
    <div id="readerBody"></div>
  </div>
</article>

<script>
/* ============ SIGNATURE: live fermentation curve ============ */
/* Same activity shape the real engine uses: relative yeast speed vs temperature,
   anchored at 25°C = 1.0, log-interpolated between measured points. */
const POINTS=[[10,0.30],[15,0.50],[20,0.71],[25,1.00],[30,1.41],[35,1.65]];
function activity(c){
  c=Math.max(10,Math.min(35,c));
  for(let i=0;i<POINTS.length-1;i++){
    const [x0,y0]=POINTS[i],[x1,y1]=POINTS[i+1];
    if(c>=x0&&c<=x1){const f=(c-x0)/(x1-x0);return Math.exp(Math.log(y0)+(Math.log(y1)-Math.log(y0))*f);}
  }
  return 1;
}
const BASE_HOURS=8; // NY-ish reference plan at 25°C
const X0=40,X1=440,Y0=30,Y1=200;
const tx=c=>X0+((c-10)/25)*(X1-X0);
const maxRate=1.65, minRate=0.30;
const ty=r=>{ // faster (higher rate) = higher on chart = lower y
  const f=(Math.log(r)-Math.log(minRate))/(Math.log(maxRate)-Math.log(minRate));
  return Y1-f*(Y1-Y0);
};
(function buildCurve(){
  let d="",a="";
  for(let c=10;c<=35;c+=0.5){
    const x=tx(c),y=ty(activity(c));
    d+=(c===10?"M":"L")+x.toFixed(1)+" "+y.toFixed(1)+" ";
  }
  a=d+`L ${X1} ${Y1} L ${X0} ${Y1} Z`;
  document.getElementById('line').setAttribute('d',d.trim());
  document.getElementById('area').setAttribute('d',a.trim());
})();
const tempEl=document.getElementById('temp');
const dot=document.getElementById('dot'),marker=document.getElementById('marker');
const timeOut=document.getElementById('timeOut'),tempLabel=document.getElementById('tempLabel'),instRead=document.getElementById('instRead'),instHint=document.getElementById('instHint');
function fmtH(h){ if(h<1)return Math.round(h*60)+" min"; const r=Math.round(h*2)/2; return (Number.isInteger(r)?r:r.toFixed(1)); }
function update(c){
  const rate=activity(c);
  const x=tx(c),y=ty(rate);
  dot.setAttribute('cx',x);dot.setAttribute('cy',y);
  marker.setAttribute('x1',x);marker.setAttribute('x2',x);marker.setAttribute('y1',y);marker.setAttribute('y2',Y1);
  const hours=BASE_HOURS/rate;
  // present as a range like the real tool
  const lo=fmtH(hours*0.82), hi=fmtH(hours*1.2);
  timeOut.innerHTML = (lo===hi? lo : lo+"–"+hi)+'<span class="u"> h</span>';
  tempLabel.textContent=c+" °C";
  instRead.textContent=c+" °C";
  let hint;
  if(c<=14) hint="Cool room. The dough takes its time; patience pays off in flavour.";
  else if(c<=28) hint="A comfortable kitchen. This is where most same-day doughs live.";
  else hint="Warm and fast. Watch it closely — it can over-prove before you expect.";
  instHint.textContent=hint;
}
tempEl.addEventListener('input',e=>update(+e.target.value));
// scrub directly on the chart
const svg=document.getElementById('curve');
function scrub(clientX){
  const box=svg.getBoundingClientRect();
  const px=( (clientX-box.left)/box.width )*460;
  let c=Math.round(10+((px-X0)/(X1-X0))*25);
  c=Math.max(10,Math.min(35,c));
  tempEl.value=c;update(c);
}
let dragging=false;
svg.addEventListener('pointerdown',e=>{dragging=true;svg.setPointerCapture(e.pointerId);scrub(e.clientX);});
svg.addEventListener('pointermove',e=>{if(dragging)scrub(e.clientX);});
svg.addEventListener('pointerup',()=>dragging=false);
update(25);

/* ============ GUIDES + ARTICLE READER ============ */
const GUIDES=[
  {
    id:"dough12", slug:"how-much-dough-for-12-inch-pizza", q:"Sizing", title:"How much dough for a 12-inch pizza?",
    snippet:"A single number gets you close — but style and thickness change it more than you'd think.",
    answer:"For a standard 12-inch round pizza, use roughly 270 g of dough for a thin Neapolitan-style base, or about 305 g for a thicker, chewier New York style.",
    body:`<p>Those figures come straight from the density each style uses. "12 inches" describes the pan, not the pizza — what sets the weight is <strong>how thick you want the finished crust</strong>, and that changes with style.</p>
    <h2>The number behind the number</h2>
    <p>Dough weight scales with the <strong>area</strong> of the base, not its diameter. A 12-inch round is about 113 square inches. Doughborough carries a density figure — grams per square inch — for each style:</p>
    <ul>
      <li><strong>Neapolitan (thin, puffy rim):</strong> ~2.39 g/in² → about 270 g</li>
      <li><strong>New York (medium, foldable):</strong> ~2.7 g/in² → about 305 g</li>
      <li><strong>Thick / pan style:</strong> higher again, measured by pan volume</li>
    </ul>
    <p>This is why scaling by eye goes wrong. Double the diameter and you don't double the dough — you roughly <strong>quadruple</strong> it, because area grows with the square of the radius.</p>
    <h2>Just tell me what to weigh</h2>
    <p>Pick your style and size in the calculator and it does the area maths, splits the total into equal balls, and gives you the flour, water, salt and yeast to hit it.</p>`,
    cta:"Size my dough", link:"/calculator.html?style=neapolitan"
  },
  {
    id:"cold", slug:"how-long-to-cold-ferment-pizza-dough", q:"Timing", title:"How long should I cold-ferment pizza dough?",
    snippet:"Overnight? Three days? The fridge is forgiving — up to a point. Here's the real window.",
    answer:"Most pizza dough cold-ferments best between 24 and 72 hours at fridge temperature (about 4 °C). Flavour deepens across that window; beyond about 4 days the dough starts to weaken.",
    body:`<p>Cold fermentation is the biggest upgrade most home pizza-makers can make, and it costs nothing but time. Chilling slows the yeast to a crawl while <strong>slow fermentation keeps building flavour</strong>.</p>
    <h2>What's actually happening in the fridge</h2>
    <p>The part most guides skip: <strong>your dough doesn't become fridge-cold the moment it goes in.</strong> It takes several hours to cool through, fermenting near room speed at first, then slowing. That "warm start" is exactly what Doughborough's refrigerator model accounts for by integrating the cooling curve.</p>
    <h2>A practical window</h2>
    <ul>
      <li><strong>24 hours:</strong> noticeably better than same-day. Clean, mild flavour.</li>
      <li><strong>48 hours:</strong> the sweet spot — complex, easy to handle.</li>
      <li><strong>72 hours:</strong> deepest flavour; watch the structure holds.</li>
      <li><strong>Beyond 4 days:</strong> gluten breaks down; dough turns slack.</li>
    </ul>
    <p>Let cold dough <strong>warm up before shaping</strong> — most cold pizza dough needs roughly 2–3 hours to warm, relax and finish proofing, though the right figure depends on style.</p>
    <h2>Let the calculator plan it</h2>
    <p>Switch to refrigerator mode, give it your fridge temperature and how long you've got, and it builds the whole staged plan with the yeast dosed for your timeline.</p>`,
    cta:"Plan a cold ferment", link:"/calculator.html?mode=cold"
  },
  {
    id:"yeast", slug:"how-much-yeast-for-pizza-dough", q:"Ingredients", title:"How much yeast does pizza dough need?",
    snippet:"Less than you think — and the right amount depends entirely on time and temperature.",
    answer:"For most pizza dough, use roughly 0.2–0.5% instant dry yeast by flour weight for a same-day rise, dropping to 0.05–0.1% for a long cold ferment. More time means less yeast.",
    body:`<p>Yeast is the most over-done ingredient in home pizza. Packet recipes call for a whole sachet because they want a fast, foolproof rise — but fast is the enemy of flavour.</p>
    <h2>Yeast and time trade off directly</h2>
    <p>It's a dial: <strong>more yeast = faster rise; less yeast = slower rise.</strong> Since slow fermentation tastes better, the skilled move is <em>less</em> yeast and <em>more</em> time.</p>
    <ul>
      <li><strong>Same-day (4–8 h):</strong> around 0.3–0.5% instant dry yeast</li>
      <li><strong>Overnight room temp (10–14 h):</strong> around 0.1–0.2%</li>
      <li><strong>Cold ferment (24–72 h):</strong> as little as 0.05–0.1%</li>
    </ul>
    <h2>The temperature catch</h2>
    <p>Those assume a normal kitchen. Warmer room, less yeast; cooler room, a touch more. Doughborough makes this adjustment automatically — you give it the temperature, it adjusts the timing and yeast dose around it.</p>
    <h2>A note on yeast types</h2>
    <p>Instant dry, active dry and fresh aren't interchangeable gram-for-gram. Active dry is ~25% weaker and wants rehydrating; fresh is about a third the strength. The calculator converts between them.</p>`,
    cta:"Get my yeast amount", link:"/calculator.html"
  },
  {
    id:"rising", slug:"why-pizza-dough-is-not-rising", q:"Troubleshooting", title:"Why is my pizza dough not rising?",
    snippet:"Nine times out of ten it's one of four things — and most are fixable mid-batch.",
    answer:"Dough that won't rise is almost always caused by dead yeast, water that was too hot, a too-cold room, or simply not enough time. A cold room is the most common — and the easiest to fix.",
    body:`<p>A flat, dense dough is disheartening, but the cause is usually mundane. Work through these in order.</p>
    <h2>1. Your kitchen is too cold</h2>
    <p>The number-one culprit. Yeast slows dramatically as temperature drops. The dough may be fine — it just needs <strong>more time or a warmer spot</strong> (in the oven with just the light on).</p>
    <h2>2. The water killed the yeast</h2>
    <p>Water above about 50 °C starts killing yeast. If your "warm" water was actually hot, the yeast is gone. It should feel <strong>cool to lukewarm</strong>, never hot.</p>
    <h2>3. The yeast was already dead</h2>
    <p>Old yeast loses potency. Test it: dissolve a little in warm water with a pinch of sugar; if it doesn't foam in 10 minutes, replace it.</p>
    <h2>4. You haven't waited long enough</h2>
    <p>With low yeast quantities, rising is slow by design. Judge by <strong>how the dough looks</strong> — puffy, domed, jiggly — not by the clock.</p>
    <h2>Avoid it next time</h2>
    <p>Most "won't rise" problems are really "wrong yeast for the temperature." Give Doughborough your room temperature and it sets the dose and a realistic window.</p>`,
    cta:"Fix my next batch", link:"/calculator.html"
  },
  {
    id:"hydration", slug:"dough-hydration-explained", q:"Fundamentals", title:"What is dough hydration, and why does it matter?",
    snippet:"The single number that decides whether your crumb is tight and chewy or open and airy.",
    answer:"Hydration is the weight of water as a percentage of the flour. Higher hydration (65%+) gives an open, airy crumb but sticky dough; lower hydration (55–60%) is firmer and easier to handle.",
    body:`<p>Hydration is baker's shorthand for how wet a dough is: <strong>water weight ÷ flour weight × 100</strong>. 650 g water to 1000 g flour is 65% hydration. It shapes the crumb more than any other number.</p>
    <h2>What hydration changes</h2>
    <ul>
      <li><strong>55–60%:</strong> firmer, easier to handle, tighter crumb — common for lower-hydration Neapolitan formulas and good for beginners.</li>
      <li><strong>60–65%:</strong> the versatile middle — typical New York and general-purpose pizza.</li>
      <li><strong>70%+:</strong> slack and sticky, needs technique — but gives the big holes of ciabatta and Roman-style pizza.</li>
    </ul>
    <h2>Why wetter is harder</h2>
    <p>More water means a slacker gluten network that flows rather than holds. The fix isn't more bench flour — that lowers your hydration and defeats the point — it's <strong>wet hands, a scraper, and gentle folding</strong>.</p>
    <h2>Flour matters too</h2>
    <p>Stronger, higher-protein flour absorbs more water. Doughborough nudges its recommended hydration based on the protein you enter.</p>
    <h2>Dial it in</h2>
    <p>Every style starts at a sensible hydration — Neapolitan around 58%, New York around 62% — and you can push it up or down to watch the water weight rebalance.</p>`,
    cta:"Explore hydration", link:"/calculator.html"
  },
  {
    id:"poolish", slug:"poolish-vs-biga", q:"Technique", title:"Poolish vs biga: what's the difference?",
    snippet:"Two classic pre-ferments, two textures. Which one your dough wants depends on the crumb you're after.",
    answer:"A poolish is a wet (100% hydration) pre-ferment that builds extensibility and mild, nutty flavour; a biga is stiff (around 50% hydration) and builds strength and a deeper, more complex taste.",
    body:`<p>A pre-ferment is a small portion of flour, water and a pinch of yeast left to mature before you build the final dough — the traditional route to flavour and structure.</p>
    <h2>Poolish — the wet one</h2>
    <p>Equal weights of flour and water (100% hydration) with a little yeast. It stays <strong>loose and bubbly</strong>, develops <strong>extensibility</strong>, and a gentle nutty aroma. Classic for supple pizza and open breads.</p>
    <h2>Biga — the stiff one</h2>
    <p>Much drier, around 50% hydration — a shaggy, firm mass. It ferments slower and builds <strong>strength and depth</strong>. Traditional for rustic Italian breads and chewier pizza.</p>
    <h2>How long do they take?</h2>
    <p>It depends on temperature far more than the label "overnight." At a warm 25 °C a poolish may mature in roughly <strong>4–8 hours</strong>; a cooler kitchen stretches it to overnight. Maturity cues — domed, bubbly, just starting to recede — matter more than a fixed number.</p>
    <h2>Which should you use?</h2>
    <ul>
      <li><strong>Tender, extensible dough and mild flavour?</strong> Poolish.</li>
      <li><strong>Strength, chew and deeper taste?</strong> Biga.</li>
    </ul>
    <h2>Let the calculator build it</h2>
    <p>Choose poolish or biga and it works out the flour, water and yeast to hold back, and when it'll be mature at your temperature.</p>`,
    cta:"Build a pre-ferment", link:"/calculator.html"
  }
];

const grid=document.getElementById('guidesGrid');
const arrow='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
GUIDES.forEach(g=>{
  const el=document.createElement('a');
  el.className='guide';el.setAttribute('data-id',g.id);
  el.href=`/guides/${g.slug}.html`;
  el.innerHTML=`<span class="q">${g.q}</span><h3>${g.title}</h3><p class="snippet">${g.snippet}</p><span class="read">Read the answer ${arrow}</span>`;
  grid.appendChild(el);
});

const reader=document.getElementById('reader'),backdrop=document.getElementById('backdrop'),readerBody=document.getElementById('readerBody');
function openArticle(id){
  const g=GUIDES.find(x=>x.id===id); if(!g)return;
  readerBody.innerHTML=`
    <div class="a-eyebrow">${g.q}</div>
    <h1>${g.title}</h1>
    <div class="a-answer">${g.answer}</div>
    ${g.body}
    <a href="${g.link}" class="a-cta">${g.cta} ${arrow}</a>
    <p class="a-meta"><a href="/guides/${g.slug}.html" style="color:var(--blush)">View the full guide page →</a></p>`;
  reader.classList.add('open');backdrop.classList.add('open');reader.setAttribute('aria-hidden','false');
  reader.scrollTop=0;document.body.style.overflow='hidden';
}
function closeArticle(){reader.classList.remove('open');backdrop.classList.remove('open');reader.setAttribute('aria-hidden','true');document.body.style.overflow='';}
// Preview drawer as progressive enhancement: plain left-click opens the drawer,
// but Ctrl/Cmd/middle-click and search crawlers follow the real href to the guide page.
grid.addEventListener('click',e=>{
  const c=e.target.closest('.guide');if(!c)return;
  if(e.metaKey||e.ctrlKey||e.shiftKey||e.button===1)return; // let the browser open the real link
  e.preventDefault();openArticle(c.getAttribute('data-id'));
});
document.querySelectorAll('[data-open]').forEach(a=>a.addEventListener('click',e=>{e.preventDefault();openArticle(a.getAttribute('data-open'));}));
document.getElementById('readerClose').addEventListener('click',closeArticle);
backdrop.addEventListener('click',closeArticle);
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeArticle();});
</script>
</body>
</html>
